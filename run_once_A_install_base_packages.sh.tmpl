#!/bin/sh

{{- if eq .chezmoi.os "darwin" }}
exit 0
{{- end}}

echo "============================"

echo ":: Installing yay"
if command -v yay; then
  echo "⚠️  yay already installed, skipping it..."
else
  pacman -S --needed git base-devel && git clone https://aur.archlinux.org/yay.git && cd yay && makepkg -si
fi
echo "🟢 Finished installing yay"

echo ":: Installing base packages"
yay --needed -S age \
    alacritty \
    alsa-firmware \
    alsa-plugins \
    alsa-utils \
    apparmor \
    arandr \
    autorandr \
    avr-gcc \
    avr-libc \
    avrdude \
    bat \
    betterlockscreen \
    binutils \
    bitwarden \
    blueman \
    bluez-utils \
    brave-bin \
    cantarell-fonts \
    chezmoi \
    clang \
    cmake \
    colordiff \
    coreutils \
    cpupower \
    diffutils \
    docker \
    dropbox \
    dropbox-cli \
    dunst \
    emacs \
    entr \
    epdfview \
    exa \
    fd \
    flameshot \
    galendae-git \
    git \
    gitflow-avh \
    google-chrome \
    gparted \
    gruvbox-material-gtk-theme-git \
    gruvbox-material-icon-theme-git \
    gucharmap \
    htop \
    i3-gaps \
    i3blocks \
    i3status \
    inotify-tools \
    insomnia-bin \
    jq \
    kitty \
    kmonad-bin \
    lazygit \
    leafpad \
    lxappearance \
    lxinput \
    neofetch \
    neovim-nightly-bin \
    nerd-fonts-jetbrains-mono \
    nitrogen \
    nnn \
    noto-fonts \
    noto-fonts-cjk \
    noto-fonts-emoji \
    pavucontrol \
    picom \
    playerctl \
    polybar \
    postman-bin \
    powerline-fonts \
    pulseaudio-ctl \
    rar \
    ripgrep \
    rofi \
    speedcrunch \
    spotify \
    terminus-font \
    thunar \
    thunar-dropbox \
    timeshift \
    tree \
    ttf-dejavu \
    ttf-droid \
    ttf-fira-code \
    ttf-font-awesome \
    ttf-inconsolata \
    ttf-indic-otf \
    ttf-liberation \
    ttf-mac-fonts \
    ttf-monofur \
    xautolock \
    xcursor-breeze \
    xcursor-breeze-serie-obsidian \
    xmonad \
    xmonad-contrib \
    xsel \
    zsh

echo "🟢 Finished installing base packages"

echo ":: Installing herdr"
if command -v herdr >/dev/null 2>&1; then
  echo "⚠️  herdr already installed, skipping it..."
else
  curl -fsSL https://herdr.dev/install.sh | sh
fi
echo "🟢 Finished installing herdr"
