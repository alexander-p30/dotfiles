# vim:syntax=bash
zstyle '*:compinit' arguments -u

# znap {{{
[[ -r ~/.config/znap/znap-core/znap.zsh ]] ||
    git clone --depth 1 -- \
        https://github.com/marlonrichert/zsh-snap.git ~/.config/znap/znap-core

source ~/.config/znap/znap-core/znap.zsh

# Start prompt
znap eval starship 'starship init zsh --print-full-init'
znap prompt

znap eval mise '~/.local/bin/mise activate zsh'

# Plugins
znap source zsh-users/zsh-autosuggestions
znap source zsh-users/zsh-syntax-highlighting
znap source ohmyzsh/ohmyzsh \
  plugins/git \
  plugins/direnv

# From Prezto
znap source sorin-ionescu/prezto
znap source sorin-ionescu/prezto \
  modules/helper \
  modules/completion \
  modules/environment \
  modules/terminal \
  modules/editor \
  modules/history \
  modules/directory \
  modules/utility

# FZF
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# Completions
znap fpath _mise 'mise completion zsh'
znap fpath _remotectl 'remotectl completion zsh'
znap fpath _rustup 'rustup completions zsh'
znap fpath _cargo 'rustup completions zsh cargo'
znap fpath _colima 'colima completion zsh'
# }}}

# Aliases {{{
source ~/.alias/git-aliases
source ~/.alias/rails-aliases
source ~/.alias/soft-aliases
source ~/.alias/system-aliases
alias mise='nocorrect mise'
# }}}

# Keep IEx history
export ERL_AFLAGS="+MIscs 2048 -kernel shell_history enabled"

# Save outer terminal before tmux overrides TERM_PROGRAM
if [ -z "$TMUX" ]; then
  export OUTER_TERM_PROGRAM="${TERM_PROGRAM}"
fi

# Avoid nested tmux
if command -v tmux &> /dev/null && [ -n "$PS1" ] && [[ ! "$TERM" =~ screen ]] && [[ ! "$TERM" =~ tmux ]] && [ -z "$TMUX" ]; then
  tmux a -t default || tmux new -s default
fi

# Restore TERM_PROGRAM inside tmux to match outer terminal
if [ -n "$TMUX" ] && [ -n "$OUTER_TERM_PROGRAM" ]; then
  export TERM_PROGRAM="$OUTER_TERM_PROGRAM"
fi

# Setup zoxide
znap eval zoxide 'zoxide init zsh'


gt() {
  REMOTE_DIR="$HOME/Projects/remote"

  selected=$(
    {
      find "$REMOTE_DIR" -mindepth 1 -maxdepth 1 -type d -name '*worktrees*' \
        -exec find {} -mindepth 1 -maxdepth 1 -type d \;
      echo "$REMOTE_DIR/tiger"
      echo "$REMOTE_DIR/neo"
      echo "$REMOTE_DIR/dragon"
    } | sed "s|^$REMOTE_DIR/||" | fzf | sed "s|^|$REMOTE_DIR/|"
  )

  [[ -n "$selected" ]] && cd "$selected"
}

how() {
  claude --model haiku -p "Answer concisely and briefly: how $*"
}

# Run gt on Ctrl-f
bindkey -s '^f' 'gt\n'

export PATH="/opt/homebrew/opt/icu4c@77/bin:$PATH"
export PATH="/opt/homebrew/opt/icu4c@77/sbin:$PATH"

# run arbitrary commands ```RUN='echo "it works"' zsh```
TEMP_RUN=$RUN
export RUN=
eval "$TEMP_RUN"
