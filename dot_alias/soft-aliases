# Neovim
alias nv="nvim"
alias cfgnv="cedit ~/.config/nvim"
alias cdnv="cd ~/.config/nvim"

# Kitty
alias cfgkt="cedit ~/.config/kitty"
alias cdkt="cd ~/.config/kitty"
alias kdiff="kitty +kitten diff"
alias ktsh="kittysh && exit"

alias lg="lazygit"
alias c="chezmoi"
alias hms="herdr-sessionizer"
alias rr="caffeinate -i git pull --rebase && caffeinate -i mix do deps.get + ecto.migrate && dexter reindex"
alias rrt="caffeinate -i git pull --rebase && caffeinate -i mix do deps.get + ecto.migrate && MIX_ENV=test caffeinate -i mix ecto.migrate && dexter reindex"
alias mixt="direnv deny; MIX_ENV=test iex -S mix; stty sane && direnv allow"
alias asdf="mise"
